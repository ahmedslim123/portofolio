# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
# /out/ is committed on request so the built, deploy-ready site lives in the
# repo (FTP its contents to InfinityFree htdocs/). Regenerate with `npm run build`.

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# raw project source assets — heavy originals (700MB+). The optimized,
# web-ready copies the site actually serves live in /public/projects/.
/projects/

# local dev log
.devlog.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
